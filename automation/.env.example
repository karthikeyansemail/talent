# ============================================
# Dev Bridge — Portable Configuration
# ============================================
# Copy this file to .env and fill in your values.
# This bridge works with ANY project — just update the paths.

# Telegram Bot Configuration
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the bot token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID
# 1. Search for @userinfobot in Telegram
# 2. Send /start — it will reply with your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Bridge Server (localhost only — not exposed to network)
BRIDGE_PORT=3377
BRIDGE_HOST=127.0.0.1

# ============================================
# Project-Specific Settings
# ============================================

# Project root — the directory Claude CLI will work in
# This is the main codebase directory (where CLAUDE.md lives)
PROJECT_ROOT=c:\path\to\your\project

# Claude CLI path
# Find yours with: powershell -Command "Get-ChildItem '$env:USERPROFILE' -Recurse -Filter 'claude.exe' -Depth 6"
# Or if installed globally: claude
CLAUDE_CLI_PATH=claude

# Task timeout in milliseconds (default: 10 minutes)
CLAUDE_TASK_TIMEOUT=600000

# Application base URL (for Playwright tests)
APP_BASE_URL=http://localhost/your-app

# Test Credentials (for Playwright login helper)
TEST_EMAIL=admin@example.com
TEST_PASSWORD=password
